<script>
	const PAGES = [
		{name: "Map", path: "/"},
		{name: "Tutorial", path: "/tutorial"},
		{name: "About", path: "/about"},
		{name: "Dev Tools Tutorial", path: `/devtutorial`},
	];
	const getPath = name => '/' + name.toLowerCase();
	PAGES.forEach(({ name, path }) => {
		if (path == window.location.pathname) document.title = name;
	});
	document.title ||= '404';
</script>